{
  "name": "gatherly",
  "version": "1.0.0",
  "private": true,
  "description": "Gatherly — a community-driven social media platform",
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3"
  }
}

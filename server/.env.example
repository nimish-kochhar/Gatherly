# === Database ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gatherly
DB_USER=gatherly_user
DB_PASSWORD=gatherly_pass

# === Redis (optional — leave blank to skip) ===
REDIS_URL=

# === Auth ===
ACCESS_TOKEN_SECRET=change-me-access-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_EXPIRY=7d

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Meilisearch (optional — leave blank to use MySQL fulltext) ===
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=gatherly_meili_key

# === App ===
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
